{
  "name": "@alango/arc-devtools-mcp",
  "version": "0.1.0",
  "description": "MCP server to control Arc via AppleScript, with optional CDP support",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gtg7784/arc-devtools-mcp.git"
  },
  "bin": {
    "arc-devtools-mcp": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "bun build src/cli.ts --outdir dist --target node --format esm",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
